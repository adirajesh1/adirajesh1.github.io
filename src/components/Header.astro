---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Writing" },
  { href: "/now", label: "Now" },
  { href: "https://github.com/adirajesh1", label: "GitHub", external: true },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string, external?: boolean) =>
  external ? false : href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header">
  <nav class="site-shell site-nav" aria-label="Primary navigation">
    <a class="brand" href="/">Aditya Rajesh</a>
    <div class="nav-links">
      {navItems.map((item) => (
        <a
          class="nav-link"
          href={item.href}
          aria-current={isActive(item.href, item.external) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </div>
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to light mode">&#9680;</button>
  </nav>
</header>

<script>
  const themeToggle = document.querySelector("[data-theme-toggle]");

  function setTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
    if (themeToggle) {
      themeToggle.textContent = theme === "dark" ? "\u263e" : "\u2600";
      themeToggle.setAttribute(
        "aria-label",
        theme === "dark" ? "Switch to light mode" : "Switch to dark mode",
      );
    }
  }

  setTheme(localStorage.getItem("theme") || "dark");

  themeToggle?.addEventListener("click", () => {
    const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    setTheme(nextTheme);
  });
</script>
