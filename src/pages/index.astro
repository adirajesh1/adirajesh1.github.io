---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { entrySlug } from "../lib/content";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const memos = (await getCollection("memos", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<SiteLayout description="The personal site of Aditya Rajesh: stats, data, technology, writing, and projects.">
  <section class="intro">
    <h1>Hi, I'm Aditya.</h1>
    <p>
      I write about stats, data, technology, and things I am trying to understand.
    </p>
    <p>
      <a href="https://github.com/adirajesh1">GitHub</a>
      <span aria-hidden="true"> / </span>
      <a href="mailto:aditya-rajesh@outlook.com">Email</a>
    </p>
  </section>

  <section class="section">
    <h2>Writing</h2>
    <div class="list">
      {blogPosts.map((post) => (
        <ContentCard
          href={`/blog/${entrySlug(post)}`}
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
        />
      ))}
    </div>
    <p><a href="/blog">All posts</a></p>
  </section>

  <section class="section">
    <h2>Memos</h2>
    <div class="list">
      {memos.map((memo) => (
        <ContentCard
          href={`/memos/${entrySlug(memo)}`}
          title={memo.data.title}
          description={memo.data.description}
          date={memo.data.date}
          tags={memo.data.tags}
        />
      ))}
    </div>
    <p><a href="/memos">All memos</a></p>
  </section>
</SiteLayout>
