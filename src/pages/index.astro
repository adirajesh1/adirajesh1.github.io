---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { entrySlug } from "../lib/content";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);

const featuredProjects = [
  {
    title: "Natural Gas Storage Forecasting",
    href: "https://github.com/adirajesh1",
    note: "building a forecasting workflow around storage changes, evaluation windows, and market-relevant assumptions.",
  },
  {
    title: "Research Article Critical Appraisal Assistant",
    href: "https://github.com/adirajesh1",
    note: "turning paper review into a more structured process for claims, methodology, limitations, and evidence quality.",
  },
  {
    title: "Personal Website",
    href: "https://github.com/adirajesh1/adirajesh1.github.io",
    note: "rebuilt this site in Astro as a cleaner home for projects, writing, and current work.",
  },
];
---

<SiteLayout description="Aditya Rajesh works on data, forecasting, markets, automation, and practical software tools.">
  <section class="intro">
    <h1>I'm <a href="/about">Aditya Rajesh</a>.</h1>
    <p>
      I work on data, forecasting, markets, and small software tools that make analysis easier.
    </p>
    <p>
      Interested in technology, automation, and practical AI tools.
    </p>
    <p class="social-links">
      <a href="https://github.com/adirajesh1">GitHub</a>
      <span aria-hidden="true"> / </span>
      <a href="mailto:aditya-rajesh@outlook.com">Email</a>
      <span aria-hidden="true"> / </span>
      <a href="https://linkedin.com/in/adirajesh">LinkedIn</a>
    </p>
  </section>

  <section class="section">
    <h2>Projects</h2>
    <div class="list">
      {featuredProjects.map((project) => (
        <article class="entry">
          <p>
            <a href={project.href}>{project.title}</a> - {project.note}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Latest</h2>
    <div class="post-list">
      {blogPosts.map((entry) => (
        <ContentCard
          href={`/blog/${entrySlug(entry)}`}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          tags={entry.data.tags}
        />
      ))}
    </div>
    <p class="more-links">
      <a href="/blog">All posts</a>
    </p>
  </section>
</SiteLayout>
