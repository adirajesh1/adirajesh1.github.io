---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { entrySlug } from "../lib/content";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);
---

<SiteLayout description="Aditya Rajesh works on data, forecasting, markets, automation, and practical software tools.">
  <section class="intro">
    <h1>I'm Aditya Rajesh.</h1>
    <p>
      I work on data, forecasting, markets, and small software tools that make analysis easier.
    </p>
    <p>
      I am interested in statistics, automation, practical AI tools, and learning in public by
      building projects that connect operations experience with technical work.
    </p>
    <p class="social-links">
      <a href="https://github.com/adirajesh1">GitHub</a>
      <span aria-hidden="true"> / </span>
      <a href="mailto:aditya-rajesh@outlook.com">Email</a>
    </p>
  </section>

  <section class="section">
    <h2>Latest</h2>
    <div class="post-list">
      {blogPosts.map((entry) => (
        <ContentCard
          href={`/blog/${entrySlug(entry)}`}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          tags={entry.data.tags}
        />
      ))}
    </div>
    <p class="more-links">
      <a href="/blog">All posts</a>
    </p>
  </section>
</SiteLayout>
