---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { entrySlug } from "../lib/content";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);

const memos = (await getCollection("memos", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const latest = [
  ...blogPosts.map((entry) => ({ ...entry, collectionLabel: "Post", href: `/blog/${entrySlug(entry)}` })),
  ...memos.map((entry) => ({ ...entry, collectionLabel: "Memo", href: `/memos/${entrySlug(entry)}` })),
].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout description="The personal site of Aditya Rajesh: stats, data, technology, writing, and projects.">
  <section class="intro">
    <h1>Hi, I'm Aditya.</h1>
    <p>
      Stats, data, technology, and notes on things I am trying to understand.
    </p>
    <p class="social-links">
      <a href="https://github.com/adirajesh1">GitHub</a>
      <span aria-hidden="true"> / </span>
      <a href="mailto:aditya-rajesh@outlook.com">Email</a>
    </p>
  </section>

  <section class="section">
    <h2>Latest</h2>
    <div class="post-list">
      {latest.map((entry) => (
        <ContentCard
          href={entry.href}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          tags={[entry.collectionLabel]}
        />
      ))}
    </div>
    <p class="more-links">
      <a href="/blog">All posts</a>
      <span aria-hidden="true"> / </span>
      <a href="/memos">All memos</a>
    </p>
  </section>
</SiteLayout>
