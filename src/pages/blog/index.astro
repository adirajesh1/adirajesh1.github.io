---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { entrySlug } from "../../lib/content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout title="Writing" description="Writing from Aditya Rajesh on data, operations, automation, and markets.">
  <header class="page-header">
    <h1>Writing</h1>
    <p>Notes on data, operations, automation, markets, and technical work.</p>
  </header>

  <div class="list">
    {posts.map((post) => (
      <ContentCard
        href={`/blog/${entrySlug(post)}`}
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        tags={post.data.tags}
      />
    ))}
  </div>
</SiteLayout>
