---
import SiteLayout from "@layouts/SiteLayout.astro";

const links = [
  {
    title: "Works in Progress",
    href: "https://worksinprogress.co/",
    description: "Long-form writing on science, technology, and progress.",
  },
  {
    title: "Mrityunjay",
    href: "https://www.amazon.com/Mrityunjay-Shivaji-Sawant/dp/8126317426",
    description: "A saved reading reference from the original site.",
  },
];
---

<SiteLayout title="Misc" description="Miscellaneous links and references collected by Aditya Rajesh.">
  <header class="page-header">
    <h1>Misc</h1>
    <p>Loose links and references.</p>
  </header>

  <div class="list">
    {links.map((link) => (
      <article class="entry">
        <h3><a href={link.href}>{link.title}</a></h3>
        <p>{link.description}</p>
      </article>
    ))}
  </div>
</SiteLayout>
