---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { entrySlug } from "../../lib/content";

const memos = (await getCollection("memos", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SiteLayout title="Memos" description="Memos and useful references from Aditya Rajesh.">
  <header class="page-header">
    <p class="eyebrow">Notes</p>
    <h1>Memos</h1>
    <p>Useful links, book notes, and compact references that deserve a permanent place.</p>
  </header>

  <div class="list">
    {memos.map((memo) => (
      <ContentCard
        href={`/memos/${entrySlug(memo)}`}
        title={memo.data.title}
        description={memo.data.description}
        date={memo.data.date}
        tags={memo.data.tags}
      />
    ))}
  </div>
</SiteLayout>
