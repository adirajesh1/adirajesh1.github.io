---
import SiteLayout from "@layouts/SiteLayout.astro";

const books = [
  {
    title: "The World for Sale",
    creator: "Javier Blas and Jack Farchy",
    status: "reading",
    notes: "Commodity markets, trading firms, and resource flows.",
  },
  {
    title: "Designing Data-Intensive Applications",
    creator: "Martin Kleppmann",
    status: "reading",
    notes: "Systems, databases, and tradeoffs behind modern software.",
  },
  {
    title: "Mrityunjay",
    creator: "Shivaji Sawant",
    status: "read",
    notes: "Historical fiction with a mythological frame and a strong point of view.",
  },
];

const games = [
  {
    title: "Factorio",
    platform: "PC",
    status: "playing",
    notes: "Automation, logistics, and production systems.",
  },
  {
    title: "Civilization VI",
    platform: "PC",
    status: "playing",
    notes: "Strategy, incentives, resource allocation, and long-term planning.",
  },
];

const reading = books.filter((book) => book.status === "reading");
const read = books.filter((book) => book.status === "read");
const playing = games.filter((game) => game.status === "playing");
const played = games.filter((game) => game.status === "played");
---

<SiteLayout title="Tracking" description="Reading and game log from Aditya Rajesh.">
  <header class="page-header">
    <h1>Tracking</h1>
    <p>Books, essays, and games, kept intentionally short.</p>
  </header>

  <section class="tracking-stack" aria-label="Current tracking">
    <article class="tracking-section">
      <h2>Reading</h2>
      <table class="tracking-table">
        <tbody>
          {reading.slice(0, 5).map((book) => (
            <tr>
              <th scope="row">{book.title}</th>
              <td>{book.creator}</td>
              <td>{book.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="tracking-section">
      <h2>Playing</h2>
      <table class="tracking-table">
        <tbody>
          {playing.slice(0, 5).map((game) => (
            <tr>
              <th scope="row">{game.title}</th>
              <td>{game.platform}</td>
              <td>{game.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>

  <section class="tracking-stack tracking-grid-secondary" aria-label="Completed tracking">
    <article class="tracking-section">
      <h2>Read</h2>
      <table class="tracking-table">
        <tbody>
          {read.slice(0, 5).map((book) => (
            <tr>
              <th scope="row">{book.title}</th>
              <td>{book.creator}</td>
              <td>{book.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="tracking-section">
      <h2>Played</h2>
      <table class="tracking-table">
        <tbody>
          {played.length === 0 && (
            <tr>
              <td colspan="3">No completed games logged yet.</td>
            </tr>
          )}
          {played.slice(0, 5).map((game) => (
            <tr>
              <th scope="row">{game.title}</th>
              <td>{game.platform}</td>
              <td>{game.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>
</SiteLayout>
