---
import SiteLayout from "@layouts/SiteLayout.astro";

const books = [
  {
    title: "Dubliners",
    creator: "James Joyce",
    status: "reading",
    notes: "Short stories about ordinary lives, small choices, and social detail.",
  },
  {
    title: "Designing Data-Intensive Applications",
    creator: "Martin Kleppmann",
    status: "reading",
    notes: "Systems, databases, and tradeoffs behind modern software.",
  },
  {
    title: "Mrityunjay",
    creator: "Shivaji Sawant",
    status: "read",
    notes: "Historical fiction with a mythological frame and a strong point of view.",
  },
];

const games = [
  {
    title: "Cities: Skylines II",
    platform: "PC",
    year: "2026",
    status: "playing",
    notes: "City systems, infrastructure, and long-term planning.",
  },
  {
    title: "Civilization VI",
    platform: "PC",
    year: "2026",
    status: "playing",
    notes: "Strategy, incentives, resource allocation, and long-term planning.",
  },
  {
    title: "Factorio",
    platform: "PC",
    year: "2024",
    status: "played",
    notes: "Automation, logistics, bottlenecks, and production systems.",
  },
  {
    title: "The Farmer Was Replaced",
    platform: "PC",
    year: "2025",
    status: "played",
    notes: "Programming logic, automation loops, and incremental optimization.",
  },
  {
    title: "Mini Metro",
    platform: "PC",
    year: "2023",
    status: "played",
    notes: "Network design, constraints, and simple systems under pressure.",
  },
  {
    title: "Balatro",
    platform: "PC",
    year: "2024",
    status: "played",
    notes: "Probability, compounding effects, and building around constraints.",
  },
  {
    title: "Portal 2",
    platform: "PC",
    year: "2024",
    status: "played",
    notes: "Spatial reasoning, puzzle design, and systems thinking.",
  },
  {
    title: "Satisfactory",
    platform: "PC",
    year: "2025",
    status: "played",
    notes: "Factory planning, resource chains, and spatial logistics.",
  },
  {
    title: "Hitman",
    platform: "PC",
    year: "2025",
    status: "played",
    notes: "Systems, constraints, and planning clean routes through messy spaces.",
  },
  {
    title: "Neon White",
    platform: "PC",
    year: "2024",
    status: "played",
    notes: "Routing, optimization, and fast iteration.",
  },
  {
    title: "Prince of Persia: The Lost Crown",
    platform: "PC",
    year: "2024",
    status: "played",
    notes: "Movement, timing, and clean level design.",
  },
  {
    title: "Dishonored",
    platform: "PC",
    year: "2025",
    status: "played",
    notes: "Systems-driven stealth, player agency, and consequences.",
  },
  {
    title: "King of the Bridge",
    platform: "PC",
    year: "2025",
    status: "played",
    notes: "Rules, deduction, and adversarial reasoning.",
  },
  {
    title: "Clone Hero",
    platform: "PC",
    year: "2025",
    status: "played",
    notes: "Rhythm, execution, and deliberate practice.",
  },
];

const reading = books.filter((book) => book.status === "reading");
const read = books.filter((book) => book.status === "read");
const playing = games.filter((game) => game.status === "playing");
const played = games.filter((game) => game.status === "played");
---

<SiteLayout title="Tracking" description="Reading and game log from Aditya Rajesh.">
  <header class="page-header">
    <h1>Tracking</h1>
    <p>Books, essays, and games through the lens of systems, design, strategy, and craft.</p>
  </header>

  <section class="tracking-stack" aria-label="Current tracking">
    <article class="tracking-section">
      <h2>Reading</h2>
      <table class="tracking-table">
        <tbody>
          {reading.slice(0, 5).map((book) => (
            <tr>
              <th scope="row">{book.title}</th>
              <td>{book.creator}</td>
              <td>{book.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="tracking-section">
      <h2>Playing</h2>
      <table class="tracking-table">
        <tbody>
          {playing.slice(0, 5).map((game) => (
            <tr>
              <th scope="row">{game.title}</th>
              <td>{game.platform}</td>
              <td>{game.year}</td>
              <td>{game.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>

  <section class="tracking-stack tracking-grid-secondary" aria-label="Completed tracking">
    <article class="tracking-section">
      <h2>Read</h2>
      <table class="tracking-table">
        <tbody>
          {read.slice(0, 5).map((book) => (
            <tr>
              <th scope="row">{book.title}</th>
              <td>{book.creator}</td>
              <td>{book.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="tracking-section">
      <h2>Played</h2>
      <table class="tracking-table">
        <tbody>
          {played.length === 0 && (
            <tr>
              <td colspan="4">No completed games logged yet.</td>
            </tr>
          )}
          {played.map((game) => (
            <tr>
              <th scope="row">{game.title}</th>
              <td>{game.platform}</td>
              <td>{game.year}</td>
              <td>{game.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>
</SiteLayout>
