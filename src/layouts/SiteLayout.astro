---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Aditya Rajesh",
  description = "Stats, data, technology, and notes from Aditya Rajesh.",
} = Astro.props;

const pageTitle = title === "Aditya Rajesh" ? title : `${title} | Aditya Rajesh`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f14" />
    <link rel="canonical" href={Astro.url} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main class="site-shell page">
      <slot />
    </main>
    <Footer />
  </body>
</html>
